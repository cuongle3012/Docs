import pandas as pd
import glob
import os

def merge_summary_files():
    # 1. Identify all CSV files starting with the keyword 'summary'
    # The glob module finds all pathnames matching a specified pattern
    file_pattern = "summary*.csv"
    file_list = glob.glob(file_pattern)

    # Check if any files were found to avoid errors
    if not file_list:
        print("No files starting with 'summary' were found in the current directory.")
        return

    print(f"Found {len(file_list)} files: {file_list}")

    # 2. Read each CSV file and store them in a list of DataFrames
    # List comprehension for concise code
    dataframes = [pd.read_csv(f) for f in file_list]

    # 3. Concatenate all DataFrames into one
    # ignore_index=True resets the row numbers for the new merged file
    merged_df = pd.concat(dataframes, ignore_index=True)

    # 4. Export to a single CSV file using Tab as the delimiter
    # Using '\t' for tab separation and 'utf-8-sig' for Excel compatibility
    output_name = "merged_summary_output.csv"
    merged_df.to_csv(output_name, sep='\t', index=False, encoding='utf-8-sig')

    print(f"Successfully merged into: {output_name}")

if __name__ == "__main__":
    merge_summary_files()
