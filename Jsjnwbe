import pandas as pd
import os
from glob import glob

# Folder containing your CSV files
input_folder = "./"   # change if needed
output_file = "report.xlsx"

# Find all CSV files starting with 'summary'
csv_files = glob(os.path.join(input_folder, "summary*.csv"))

# Create Excel writer
with pd.ExcelWriter(output_file, engine="openpyxl") as writer:
    for file in csv_files:
        try:
            # Read CSV
            df = pd.read_csv(file)

            # Extract sheet name (max 31 chars for Excel)
            sheet_name = os.path.basename(file).replace(".csv", "")[:31]

            # Write to Excel sheet
            df.to_excel(writer, sheet_name=sheet_name, index=False)

            print(f"Added {file} -> sheet '{sheet_name}'")

        except Exception as e:
            print(f"Error processing {file}: {e}")

print(f"\nExcel report generated: {output_file}")
